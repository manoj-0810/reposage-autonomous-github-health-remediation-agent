# ═══════════════════════════════════════════════════════════════════════════
# RepoSage — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (required) ───────────────────────────────────────────────
# Kimi K2 — used by Orchestrator, Prioritizer, and Fix agents
KIMI_API_KEY=your-kimi-k2-api-key-here

# Gemini 2.5 Flash — used by fast parallel sub-audits (DependencyAuditor, etc.)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://reposage:reposage@localhost:5432/reposage

# ── Redis ─────────────────────────────────────────────────────────────────
# Redis connection string (for job queue — rq or celery)
REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────
# FastAPI port
PORT=8000

# ── GitHub ────────────────────────────────────────────────────────────────
# Optional: default GitHub token for unauthenticated requests
# (users can also provide their own token via the UI)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
