# ═══════════════════════════════════════════════════════════════════════════
# RepoSage — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (ALL FREE TIER) ──────────────────────────────────────────

# Groq — replaces Kimi K2 — used by CodeSmellDetector, Prioritizer, FixAgent
# FREE TIER: 14,400 requests/day | Get key: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Gemini 2.5 Flash — used by DependencyAuditor, TestCoverageAnalyzer, SecurityScanner
# FREE TIER: 1M tokens/day | Get key: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://reposage:reposage@db:5432/reposage

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000

# ── GitHub ────────────────────────────────────────────────────────────────
# Get from: GitHub → Settings → Developer Settings → Personal Access Tokens
# Scopes needed: repo (to create Issues & PRs)
GITHUB_TOKEN=ghp_your_token_here
